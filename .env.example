# LiveKit configuration
LIVEKIT_URL=wss://your-livekit-cloud-url.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Token server configuration
TOKEN_SERVER_PORT=8080
TOKEN_SERVER_HOST=0.0.0.0

# Google Gemini configuration
GOOGLE_API_KEY=your_google_api_key
GOOGLE_REALTIME_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GOOGLE_REALTIME_VOICE=Kore
GOOGLE_REALTIME_LANGUAGE=en-US
GOOGLE_STT_LANGUAGES=en-US
GOOGLE_STT_DETECT_LANGUAGE=0
GOOGLE_TTS_LANGUAGE=en-US

# Gmail for email tools
GMAIL_APP_PASSWORD=your_gmail_app_password
GMAIL_USER=your_email@gmail.com

# Mem0 memory
MEM0_API_KEY=your_mem0_api_key

# Lex settings
MEMORY_USER_ID=YourName
LEX_ENABLE_INITIAL_GREETING=1
